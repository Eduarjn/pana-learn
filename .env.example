# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Bunny Stream ─────────────────────────────────────────────────────────────
# Valores públicos (usados no iframe embed e na URL CDN)
# A BUNNY_API_KEY fica nos SECRETS da Edge Function (nunca aqui!)
VITE_BUNNY_LIBRARY_ID=661515
VITE_BUNNY_CDN_HOSTNAME=vz-xxxxx.b-cdn.net

# ── Asaas (pagamentos) ──────────────────────────────────────────────────────
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/api/v3
ASAAS_API_KEY=your-asaas-api-key
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=your-webhook-secret-token

# ── App ──────────────────────────────────────────────────────────────────────
VITE_APP_URL=https://panalearn.com
